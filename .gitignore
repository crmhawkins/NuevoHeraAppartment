# [2026-04-21] Uploads de clientes: NUNCA en git.
# Esto evita que un redeploy con 'rm -rf *' + git clone restaure versiones
# antiguas O que archivos subidos se pierdan por no estar trackeados.
/public/imagesCliente
/storage/framework/sessions/*
!/storage/framework/sessions/.gitignore
/storage/framework/cache/*
