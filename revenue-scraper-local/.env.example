# Configuracion del scraper de prueba

# Listings de prueba para Airbnb (1 URL por linea, sin comillas)
AIRBNB_TEST_URLS=https://www.airbnb.es/rooms/12345678,https://www.airbnb.es/rooms/87654321

# Listings de prueba para Booking
BOOKING_TEST_URLS=https://www.booking.com/hotel/es/algeciras-centro-1.es.html,https://www.booking.com/hotel/es/otro.es.html

# Rango de fechas a scrapear (formato ISO)
FECHA_DESDE=2026-05-01
FECHA_HASTA=2026-05-15

# Timing humano (segundos entre requests)
DELAY_MIN=5
DELAY_MAX=30

# Salida
OUTPUT_DIR=./output
