                                    <div class="booking-reservation-status-title">Pendiente de calcular</div>
                                    <div class="booking-reservation-status-text">Completa los datos para ver el precio</div>
                                </div>
                            @endif
                        </div>
                        
                        <button class="booking-reservation-btn {{ ($precioTotal && isset($disponible) && $disponible) ? 'booking-reservation-btn-active' : 'booking-reservation-btn-disabled' }}" 
                                {{ (!isset($disponible) || !$disponible || !$precioTotal) ? 'disabled' : '' }}>
                            <i class="fas {{ ($precioTotal && isset($disponible) && $disponible) ? 'fa-calendar-check' : 'fa-lock' }}"></i>
                            @if(isset($disponible) && !$disponible)
                                No disponible
                            @elseif($precioTotal)
                                Reservar ahora
                            @else
                                Precio no disponible
                            @endif
                        </button>
                    @else
                        <div class="booking-alert booking-alert-info">
                            <i class="fas fa-info-circle"></i>
                            <div>
                                <strong>Selecciona fechas</strong>
                                <p>Completa el formulario para ver disponibilidad y precio.</p>
                            </div>
                        </div>
                    @endif
                    
                    <a href="{{ route('web.reservas.portal', request()->only(['fecha_entrada', 'fecha_salida', 'adultos', 'ninos'])) }}" 
                       class="booking-reservation-link">
                        <i class="fas fa-search"></i> Modificar fechas
                    </a>
                </div>
            </div>
        </div>
    </div>
    
