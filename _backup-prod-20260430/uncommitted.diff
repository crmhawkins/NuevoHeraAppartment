+    private function renderizarDesdeMetadata(array $metadata): ?string
+    {
+        $tmpl = $metadata['template'] ?? null;
+        if (!is_array($tmpl)) return null;
+        $name = $tmpl['name'] ?? null;
+        $lang = $tmpl['language']['code'] ?? 'es';
