APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

# MIR (Ministerio del Interior - Registro de Viajeros)
MIR_USERNAME=
MIR_PASSWORD=

# WordPress CRM Integration
WORDPRESS_API_TOKEN=

# WhatsApp Tools API Key (used by external WhatsApp integration service)
WHATSAPP_TOOLS_API_KEY=

# Channex Channel Manager
CHANNEX_URL=https://app.channex.io/api/v1
CHANNEX_TOKEN=
CHANNEX_API_TOKEN=
CHANNEX_WEBHOOK_SECRET=

# Stripe Payment Processing
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# AI Translation Service
AI_TRANSLATION_URL=
AI_TRANSLATION_API_KEY=
AI_TRANSLATION_MODEL=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
